# ═══════════════════════════════════════════════════════════════════
# JayWiki — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────
DB_CONNECTION_STRING=

# ── Google OAuth ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Microsoft OAuth ─────────────────────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=

# ── Not currently used ──────────────────────────────────────────────
# Reserved for future Microsoft Graph API integration.
# MICROSOFT_CLIENT_SECRET_VALUE=
# MICROSOFT_CLIENT_SECRET_ID=

# ── Frontend ────────────────────────────────────────────────────────
# Development:
# Production:
NG_API_BASE_URL=