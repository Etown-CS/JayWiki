# ═══════════════════════════════════════════════════════════════════
# JayWiki — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Database ────────────────────────────────────────────────────────
ConnectionStrings__DefaultConnection=

# ── Google OAuth ────────────────────────────────────────────────────
Authentication__Google__ClientId=

# ── Microsoft OAuth ─────────────────────────────────────────────────
Authentication__Microsoft__ClientId=
Authentication__Microsoft__TenantId=

# ── Not currently used ──────────────────────────────────────────────
# Reserved for future Microsoft Graph API integration.
# MICROSOFT_CLIENT_SECRET_VALUE=
# MICROSOFT_CLIENT_SECRET_ID=

# ── Frontend ────────────────────────────────────────────────────────
# Development: http://localhost:5227
# Production:  https://jaywiki-api-ms.azurewebsites.net
NG_API_BASE_URL=http://localhost:5227