# ═══════════════════════════════════════════════════════════════════
# JayWiki — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════════════════

# ── Database (ASP.NET Core double-underscore format) ────────────────
ConnectionStrings__DefaultConnection=

# ── Azure Blob Storage (ASP.NET Core) ─────────
AZURE_BLOB_CONNECTION_STRING=

# ── Auth — Backend (ASP.NET Core double-underscore format) ──────────
Authentication__Google__ClientId=
Authentication__Microsoft__ClientId=
Authentication__Microsoft__TenantId=

# ── Auth — Frontend (set-env.mjs) ───────────────────────────────────
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
MICROSOFT_TENANT_ID=
MICROSOFT_API_SCOPE=

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SIGNING_KEY=

# ── Frontend ─────────────────────────────────────────────────────────
NG_API_BASE_URL=

# ── CORS ─────────────────────────────────────────────────────────────
# Overrides appsettings.json Cors:AllowedOrigins in development.
# In production, configure CORS origins via environment/app settings (e.g., Cors__AllowedOrigins__0).
Cors__AllowedOrigins__0=

# ── Not currently used (reserved for future Microsoft Graph API integration) ──
# MICROSOFT_CLIENT_SECRET_VALUE=
# MICROSOFT_CLIENT_SECRET_ID=